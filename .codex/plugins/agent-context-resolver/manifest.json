{
  "schema": "codex.plugin.agent-context-resolver.v0",
  "id": "dotfiles.agent-context-resolver",
  "repo": "fatb4f/dotfiles",
  "runtime": {
    "requires": [
      "sh",
      "jq"
    ],
    "externalRepos": false,
    "cueAtRuntime": false
  },
  "entrypoints": {
    "hook": ".codex/plugins/agent-context-resolver/scripts/agent-context-resolver-hook",
    "cli": ".codex/plugins/agent-context-resolver/scripts/resolve-agent-context"
  },
  "generated": {
    "turnStartFragments": ".codex/plugins/agent-context-resolver/generated/turn_start_fragments.json",
    "promptRoutes": ".codex/plugins/agent-context-resolver/generated/prompt_routes.json",
    "routeInventory": ".codex/plugins/agent-context-resolver/generated/route_inventory.json",
    "fragmentInventory": ".codex/plugins/agent-context-resolver/generated/fragment_inventory.json"
  },
  "denies": [
    "external factory root lookup",
    "external contract.cuemod root lookup at runtime",
    "broad repo scan",
    "raw transcript forwarding",
    "raw registry dump",
    "unselected fragment injection",
    "runtime route execution"
  ]
}
