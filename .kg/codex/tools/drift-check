#!/usr/bin/env sh
set -eu

format=json
mode=full
facts=
phase=

while [ "$#" -gt 0 ]; do
	case "$1" in
	--format)
		[ "$#" -ge 2 ] || exit 2
		format=$2
		shift 2
		;;
	--mode)
		[ "$#" -ge 2 ] || exit 2
		mode=$2
		shift 2
		;;
	--facts)
		[ "$#" -ge 2 ] || exit 2
		facts=$2
		shift 2
		;;
	--phase)
		[ "$#" -ge 2 ] || exit 2
		phase=$2
		shift 2
		;;
	*)
		printf 'drift-check: unknown argument: %s\n' "$1" >&2
		exit 2
		;;
	esac
done

case "$format" in
json | cue) ;;
*)
	printf 'drift-check: unsupported --format %s\n' "$format" >&2
	exit 2
	;;
esac

case "$mode" in
full | gate | repo | patch | phase | promotion) ;;
*)
	printf 'drift-check: unsupported --mode %s\n' "$mode" >&2
	exit 2
	;;
esac

if [ -n "$phase" ]; then
	case "$phase" in
	graph-state-phase-one | graph-state-phase-two) ;;
	*)
		printf 'drift-check: unsupported --phase %s\n' "$phase" >&2
		exit 2
		;;
	esac
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
facts_json=$(mktemp "${TMPDIR:-/tmp}/codex-drift-facts.XXXXXX.json")
facts_cue=$(mktemp "${TMPDIR:-/tmp}/codex-drift-facts.XXXXXX.cue")
promotion_json=$(mktemp "${TMPDIR:-/tmp}/codex-promotion-facts.XXXXXX.json")
promotion_cue=$(mktemp "${TMPDIR:-/tmp}/codex-promotion-facts.XXXXXX.cue")
trap 'rm -f "$facts_json" "$facts_cue" "$promotion_json" "$promotion_cue"' EXIT HUP INT TERM

if [ -n "$facts" ]; then
	cp "$facts" "$facts_json"
else
	"$repo_root/.kg/codex/tools/drift-facts" >"$facts_json"
fi

{
	printf 'package codexdrift\n\n_observedFacts: '
	cat "$facts_json"
	printf '\n'
} >"$facts_cue"

case "$mode" in
gate | promotion)
	"$repo_root/.kg/codex/tools/promotion-facts" >"$promotion_json"
	{
		printf 'package codexdrift\n\n_observedPromotionFacts: '
		cat "$promotion_json"
		printf '\n'
	} >"$promotion_cue"
	;;
*)
	{
		printf 'package codexdrift\n\n_observedPromotionFacts: {schema: "codex-promotion-facts.v1", phases: {}}\n'
	} >"$promotion_cue"
	;;
esac

cue_files=
for cue_dir in \
	"$repo_root/.kg/codex" \
	"$repo_root/.kg/codex/core" \
	"$repo_root/.kg/codex/vocab" \
	"$repo_root/.kg/codex/ext" \
	"$repo_root/.kg/codex/aggregate"; do
	for cue_file in "$cue_dir"/*.cue; do
		[ -e "$cue_file" ] || continue
		cue_files="$cue_files $cue_file"
	done
done

case "$mode" in
full)
	expr='(#FullDriftKG & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {repo: _observedFacts.repo, patch: _observedFacts.patch}}).findings'
	;;
gate)
	expr='(#FullDriftGate & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {repo: _observedFacts.repo, patch: _observedFacts.patch, promotion: _observedPromotionFacts}}).findings'
	;;
repo)
	expr='(#RepoDriftKG & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {repo: _observedFacts.repo}}).findings'
	;;
patch)
	expr='(#PatchDriftKG & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {patch: _observedFacts.patch}}).findings'
	;;
phase)
	if [ -n "$phase" ]; then
		expr='(#PhaseWatchdogStatus & {findings: (#FullDriftKG & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {repo: _observedFacts.repo, patch: _observedFacts.patch}}).findings}).promotionStatus.phases["'"$phase"'"]'
	else
		expr='(#PhaseWatchdogStatus & {findings: (#FullDriftKG & {schema: "codex-drift-kg.v1", model: latticeReference, facts: {repo: _observedFacts.repo, patch: _observedFacts.patch}}).findings}).promotionStatus'
	fi
	;;
promotion)
	expr='(#PromotionGateStatus & {facts: _observedPromotionFacts}).findings'
	;;
esac

cue export $cue_files "$facts_cue" "$promotion_cue" -e "$expr" --out "$format"
